#!/bin/bash

# Fallback if CONFIG_DIR not set by sketchybar
CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Color Palette #####
BAR_BG=0x4a181a22
BAR_BORDER=0x2ab0b8cc
PILL_BG=0x5a363537
PILL_BORDER=0x1a363537
WHITE=0xfff7f1ff
WHITE_50=0x998b888f

##### Nerd Font Font Awesome Icons (literal unicode) #####
ICON_APPLE=""      # fa-apple
ICON_TERMINAL=""   # fa-desktop
ICON_GLOBE=""      # fa-globe
ICON_CODEX=""      # fa-terminal
ICON_CURSOR=""     # fa-code
ICON_DISCORD=""    # fa-discord
ICON_NOTES=""      # fa-sticky-note
ICON_SLACK=""      # fa-slack
ICON_SPOTIFY=""    # fa-spotify
ICON_VOLUME=""     # fa-volume-up
ICON_WIFI=""       # fa-wifi

##### Bar Appearance #####
sketchybar --bar \
  position=top \
  topmost=window \
  height=40 \
  color=$BAR_BG \
  border_color=$BAR_BORDER \
  border_width=1 \
  shadow=off \
  padding_left=2 \
  padding_right=2 \
  margin=10 \
  y_offset=0 \
  corner_radius=16 \
  blur_radius=64

if command -v sketchybar-toggle >/dev/null 2>&1; then
  pkill -x sketchybar-toggle 2>/dev/null || true
  sketchybar-toggle &
fi

##### Defaults #####
default=(
  icon.font="Hack Nerd Font:Bold:14.0"
  label.font="Hack Nerd Font:SemiBold:12.0"
  icon.color=$WHITE
  label.color=$WHITE
  icon.padding_left=5
  icon.padding_right=5
  label.padding_left=3
  label.padding_right=5
  padding_left=2
  padding_right=2
  background.drawing=off
  background.height=30
  background.corner_radius=10
  background.color=$PILL_BG
  background.border_color=$PILL_BORDER
  background.border_width=1
)
sketchybar --default "${default[@]}"

##### Left: Apple + Workspaces #####
sketchybar --add item apple left \
  --set apple \
    icon="$ICON_APPLE" \
    icon.color=$WHITE \
    icon.font="Hack Nerd Font:Bold:20.0" \
    icon.padding_left=10 \
    icon.padding_right=8 \
    label.drawing=off \
    click_script="open -a 'System Settings'"

# Spacer between islands
sketchybar --add item spacer_left left \
  --set spacer_left \
    icon.drawing=off \
    label.drawing=off \
    width=8

##### Left Island 2: Workspaces #####
sketchybar --add event aerospace_workspace_change

# Workspace icons based on app assignments
ICON_FOLDER=""    # fa-folder

declare -A WORKSPACE_ICONS
WORKSPACE_ICONS=(
  [1]="$ICON_TERMINAL"  # Terminal
  [2]="$ICON_GLOBE"     # Chrome/Safari
  [3]="$ICON_CODEX"     # Codex
  [4]="$ICON_CURSOR"    # Cursor
  [5]="$ICON_FOLDER"
  [6]="$ICON_NOTES"     # Notes
  [7]="$ICON_SLACK"     # Slack
  [8]="$ICON_DISCORD"   # Discord
  [9]="$ICON_SPOTIFY"   # Spotify
)

workspaces=$(aerospace list-workspaces --all)

for sid in $workspaces; do
  icon="${WORKSPACE_ICONS[$sid]:-$sid}"

  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      icon="$icon" \
      icon.color=$WHITE_50 \
      icon.font="Hack Nerd Font:Bold:14.0" \
      icon.padding_left=7 \
      icon.padding_right=3 \
      label="$sid" \
      label.color=$WHITE_50 \
      label.font="Hack Nerd Font:Bold:11.0" \
      label.padding_left=0 \
      label.padding_right=7 \
      background.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

##### Right: Status Pills #####

sketchybar --add item date right \
  --set date \
    update_freq=60 \
    icon.drawing=off \
    label.font="Hack Nerd Font:Bold:12.0" \
    label.padding_left=10 \
    label.padding_right=10 \
    background.drawing=on \
    script="$PLUGIN_DIR/date.sh" \
    click_script="$PLUGIN_DIR/click_calendar.sh"

sketchybar --add item clock right \
  --set clock \
    update_freq=10 \
    icon.drawing=off \
    label.font="Hack Nerd Font:Bold:12.0" \
    label.padding_left=10 \
    label.padding_right=10 \
    background.drawing=on \
    script="$PLUGIN_DIR/clock.sh" \
    click_script="$PLUGIN_DIR/click_clock.sh"

sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    icon.color=$WHITE \
    icon.font="Hack Nerd Font:Bold:16.0" \
    icon.padding_left=10 \
    icon.padding_right=4 \
    label.font="Hack Nerd Font:Bold:11.0" \
    label.padding_left=0 \
    label.padding_right=10 \
    background.drawing=on \
    script="$PLUGIN_DIR/battery.sh" \
    click_script="$PLUGIN_DIR/click_battery.sh" \
  --subscribe battery system_woke power_source_change

sketchybar --add item wifi right \
  --set wifi \
    icon="$ICON_WIFI" \
    icon.color=$WHITE \
    icon.font="Hack Nerd Font:Bold:14.0" \
    icon.padding_left=10 \
    icon.padding_right=10 \
    label.drawing=off \
    background.drawing=on \
    click_script="open 'x-apple.systempreferences:com.apple.Network-Settings.extension'"

sketchybar --add item volume right \
  --set volume \
    icon="$ICON_VOLUME" \
    icon.color=$WHITE \
    icon.font="Hack Nerd Font:Bold:14.0" \
    icon.padding_left=10 \
    icon.padding_right=10 \
    label.drawing=off \
    background.drawing=on \
    scroll_texts=off \
    script="$PLUGIN_DIR/volume.sh" \
    click_script="$PLUGIN_DIR/click_sound.sh" \
  --subscribe volume volume_change

##### Initialize #####
sketchybar --update
