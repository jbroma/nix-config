{
	"base_keymap": "VSCode",
	"theme": "GitHub Dark",
	"preview_tabs": {
		"enabled": false
	},
	"focus_follows_mouse": {
		"enabled": true
	},
	"toolbar": {
		"code_actions": false,
		"agent_review": false,
		"selections_menu": false,
		"quick_actions": false,
		"breadcrumbs": false
	},
	"status_bar": {
		"show_active_file": false,
		"cursor_position_button": false,
		"active_language_button": false
	},
	"tab_bar": {
		"show_nav_history_buttons": false,
		"show_tab_bar_buttons": false,
		"show_pinned_tabs_in_separate_row": false,
		"show": false
	},
	"scrollbar": {
		"axes": {
			"horizontal": false
		},
		"diagnostics": "error",
		"git_diff": false,
		"show": "never"
	},
	"minimap": {
		"current_line_highlight": "all",
		"thumb": "hover",
		"show": "always"
	},
	"diagnostics": {
		"button": true,
		"lsp_pull_diagnostics": {
			"debounce_ms": 90
		},
		"inline": {
			"enabled": true
		},
		"include_warnings": true
	},
	"buffer_font_family": "Hack Nerd Font",
	"buffer_font_size": 12,
	"buffer_font_features": {
		"liga": false
	},
	"ui_font_family": ".SystemUIFont",
	"ui_font_size": 15,
	"icon_theme": "Material Icon Theme",
	"hard_tabs": true,
	"tab_size": 4,
	"format_on_save": "on",
	"soft_wrap": "editor_width",
	"show_whitespaces": "none",
	"git": {
		"inline_blame": {
			"enabled": true
		}
	},
	"terminal": {
		"font_family": "Hack Nerd Font",
		"font_size": 14,
		"line_height": "standard",
		"shell": {
			"with_arguments": {
				"program": "zsh",
				"args": ["-l"]
			}
		},
		"working_directory": "current_project_directory"
	},
	"autosave": "off",
	"languages": {
		"JavaScript": {
			"formatter": "prettier",
			"format_on_save": "on"
		},
		"TypeScript": {
			"formatter": "prettier",
			"format_on_save": "on"
		},
		"TSX": {
			"formatter": "prettier",
			"format_on_save": "on"
		},
		"JSON": {
			"formatter": "prettier",
			"format_on_save": "on"
		},
		"JSONC": {
			"formatter": "prettier",
			"format_on_save": "on"
		},
		"Markdown": {
			"formatter": "prettier",
			"format_on_save": "on",
			"soft_wrap": "editor_width"
		},
		"YAML": {
			"formatter": "prettier",
			"format_on_save": "on"
		},
		"Python": {
			"tab_size": 4,
			"hard_tabs": false
		},
		"Rust": {
			"formatter": "language_server",
			"format_on_save": "on"
		}
	},
	"lsp": {
		"nil": {
			"initialization_options": {
				"diagnostics": {
					"ignored": ["unused_binding", "unused_with"],
					"excludedFiles": []
				},
				"nix": {
					"flake": {
						"autoEvalInputs": false,
						"autoArchive": true
					}
				}
			}
		},
		"rust-analyzer": {
			"initialization_options": {
				"checkOnSave": true,
				"check": {
					"command": "clippy"
				}
			}
		}
	},
	"prettier": {
		"semi": true,
		"singleQuote": true,
		"tabWidth": 4,
		"trailingComma": "all",
		"useTabs": true
	},
	"agent": {
		"default_model": {
			"provider": "zed.dev",
			"model": "claude-sonnet-4"
		},
		"always_allow_tool_actions": true
	},
	"agent_servers": {
		"claude-acp": {
			"type": "registry",
			"env": {
				"ANTHROPIC_MODEL": "opus"
			}
		}
	},
	"edit_predictions": {
		"mode": "eager"
	},
	"show_edit_predictions": true
}
